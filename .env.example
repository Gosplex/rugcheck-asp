# RugCheck configuration. Copy to `.env` and fill in. Never commit `.env`.

# OpenRouter API key — powers the AI analyst layer.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which model to reason with. Pick any from https://openrouter.ai/models
# (OpenRouter uses dotted version slugs; append ":free" variants for zero cost).
# Examples: anthropic/claude-opus-4.8, anthropic/claude-sonnet-4.6, deepseek/deepseek-chat:free
OPENROUTER_MODEL=anthropic/claude-opus-4.8

# --- Data source (OKX Onchain OS) ---
# Local dev uses the `onchainos` CLI automatically (no keys needed).
# For DEPLOY (Render / Cloud Run / Firebase), set OKX Web3 API credentials and
# RugCheck switches to HTTP automatically. Get keys at https://web3.okx.com (DEX/Web3 API).
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_PROJECT_ID=
# Optional overrides:
# OKX_API_BASE=https://web3.okx.com
# RUGCHECK_SOURCE=http   # force http|cli (default: http when OKX_API_KEY is set, else cli)

# Optional: port for the local server (default 8787)
PORT=8787
